#!/usr/bin/env ruby
# Walks the outbox pattern end to end: happy path, at-least-once redelivery,
# and the crash-gap recovery via the relay. Run with: bin/demo
require_relative "../config/environment"

# Inline so every side effect is visible the moment it happens.
ActiveJob::Base.queue_adapter = :inline
ActiveRecord::Base.logger = nil

def banner(text) = puts "\n\e[1;33m== #{text}\e[0m"
def say(text) = puts "   #{text}"

def show_events(order)
  order.events.reload.chronologically.each do |event|
    marker = event.dispatched? ? "\e[32mdispatched\e[0m" : "\e[31mSTRANDED\e[0m"
    say "event #{event.action.ljust(14)} #{marker}  payload=#{event.payload}"
  end
end

def show_effects(order)
  say "confirmed? #{order.reload.confirmed?}   on hand (#{order.item}): #{Inventory.on_hand(order.item)}"
end

[ Inventory::Adjustment, Order::Confirmation, Event, Order::Payment, Order::Shipment, Order ].each(&:delete_all)

banner "1. Happy path: place + pay, fanout runs after commit"
order = Order.place(customer_email: "bob@example.com", item: "keyboard", quantity: 2)
order.pay
show_events(order)
show_effects(order)

banner "2. At-least-once: the relay re-delivers, consumers stay idempotent"
say "simulating a crash mid-fanout: jobs were enqueued but the marker write was lost"
paid_event = order.events.find_by(action: "order.paid")
paid_event.update_column(:dispatched_at, nil)
paid_event.dispatch
say "re-dispatched #{paid_event.action}: no duplicate confirmation, no double stock hit"
show_effects(order)

banner "3. The crash gap: commit succeeded, fanout never ran"
Event.dispatch_after_create = false
stranded_order = Order.place(customer_email: "carol@example.com", item: "mouse")
stranded_order.pay
Event.dispatch_after_create = true
show_events(stranded_order)
show_effects(stranded_order)
say "the fact is durable (rows above) but nobody reacted -- this is what"
say "after_create_commit alone loses when the process dies at the wrong moment"

banner "4. Relay: the recurring sweep finds stranded events and re-fans-out"
say "relay sees nothing yet (events younger than #{Event::RELAY_AFTER.inspect} may still get their hook):"
say "stranded candidates: #{Event.stranded.count}"
stranded_order.events.each { |e| e.update_column(:created_at, 2.minutes.ago) }
say "2 minutes later... stranded candidates: #{Event.stranded.count}"
Event::RelayJob.perform_now
show_events(stranded_order)
show_effects(stranded_order)

banner "Done"
say "events total: #{Event.count}, all dispatched: #{Event.where(dispatched_at: nil).none?}"
